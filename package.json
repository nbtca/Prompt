{
  "name": "@nbtca/prompt",
  "version": "1.0.25",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "bin": {
    "nbtca": "bin/nbtca-welcome.js",
    "nbtca-welcome": "bin/nbtca-welcome.js"
  },
  "files": [
    "dist",
    "bin/nbtca-welcome.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "start": "node dist/index.js",
    "dev": "tsx src/index.ts",
    "dev:watch": "tsx watch src/index.ts",
    "build": "tsc",
    "postbuild": "node scripts/copy-assets.js",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "prepublishOnly": "npm run build",
    "test": "npm run build && bash scripts/test-cli.sh"
  },
  "keywords": [
    "cli",
    "terminal",
    "welcome",
    "nbtca",
    "ningbotech",
    "computer-association",
    "tui",
    "interactive"
  ],
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "chalk": "^5.6.2",
    "gradient-string": "^3.0.0",
    "ical.js": "^2.2.1",
    "marked": "^15.0.12",
    "marked-terminal": "^7.0.0",
    "open": "^11.0.0"
  },
  "devDependencies": {
    "@types/gradient-string": "^1.1.6",
    "@types/marked-terminal": "^3.1.3",
    "@types/node": "^22.19.17",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.12.0"
  },
  "author": "m1ngsama <contact@m1ng.space>",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/nbtca/prompt.git"
  },
  "bugs": {
    "url": "https://github.com/nbtca/prompt/issues"
  },
  "homepage": "https://github.com/nbtca/prompt#readme",
  "description": "NBTCA Prompt - Minimalist CLI tool for NingboTech Computer Association"
}
